<UserControl x:Class="Romer.UI.Controls.RomerCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="360"
             Height="360">
    <Grid>
        <Grid x:Name="ContentRoot"
              Width="360"
              Height="360"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ScalePart" ScaleX="1" ScaleY="1" />
                    <RotateTransform x:Name="RotatePart" Angle="0" />
                    <TranslateTransform x:Name="TranslatePart" X="0" Y="0" />
                </TransformGroup>
            </Grid.RenderTransform>

            <Rectangle x:Name="DragSurface"
                       Fill="Transparent"
                       Stroke="#00FFFFFF"
                       StrokeThickness="1"
                       MouseLeftButtonDown="DragSurface_OnMouseLeftButtonDown" />

            <Canvas Width="360" Height="360" IsHitTestVisible="False">
                <!-- Long dashed guide lines that extend the inner square edges for map margin alignment. -->
                <Line X1="60" Y1="-5000" X2="60" Y2="5000" Stroke="#B8FFFFFF" StrokeThickness="1.8" Opacity="0.45" StrokeDashArray="5,4" />
                <Line X1="300" Y1="-5000" X2="300" Y2="5000" Stroke="#B8FFFFFF" StrokeThickness="1.8" Opacity="0.45" StrokeDashArray="5,4" />
                <Line X1="-5000" Y1="60" X2="5000" Y2="60" Stroke="#B8FFFFFF" StrokeThickness="1.8" Opacity="0.45" StrokeDashArray="5,4" />
                <Line X1="-5000" Y1="300" X2="5000" Y2="300" Stroke="#B8FFFFFF" StrokeThickness="1.8" Opacity="0.45" StrokeDashArray="5,4" />
                <Line X1="60" Y1="-5000" X2="60" Y2="5000" Stroke="#CC111111" StrokeThickness="0.9" Opacity="0.95" StrokeDashArray="5,4" />
                <Line X1="300" Y1="-5000" X2="300" Y2="5000" Stroke="#CC111111" StrokeThickness="0.9" Opacity="0.95" StrokeDashArray="5,4" />
                <Line X1="-5000" Y1="60" X2="5000" Y2="60" Stroke="#CC111111" StrokeThickness="0.9" Opacity="0.95" StrokeDashArray="5,4" />
                <Line X1="-5000" Y1="300" X2="5000" Y2="300" Stroke="#CC111111" StrokeThickness="0.9" Opacity="0.95" StrokeDashArray="5,4" />

                <Path Fill="#66F1F2F4" Stroke="#AA2A2A2A" StrokeThickness="1.6" SnapsToDevicePixels="True">
                    <Path.Data>
                        <GeometryGroup FillRule="EvenOdd">
                            <RectangleGeometry Rect="8,8,344,344" RadiusX="12" RadiusY="12" />
                            <RectangleGeometry Rect="49,49,262,262" RadiusX="8" RadiusY="8" />
                        </GeometryGroup>
                    </Path.Data>
                </Path>
                <!-- Keep center visually transparent but non-zero alpha so layered window still gets mouse events. -->
                <Rectangle Width="262" Height="262" Canvas.Left="49" Canvas.Top="49" Fill="#01000000" RadiusX="8" RadiusY="8" />
                <Path x:Name="TemplatePathShadow" Stroke="#AA111111" StrokeThickness="2.2" SnapsToDevicePixels="True" />
                <Path x:Name="TemplatePath" Stroke="#F8FCFF" StrokeThickness="1.2" SnapsToDevicePixels="True" />
                <Canvas x:Name="MarkingsLayer" />
            </Canvas>

            <Line x:Name="RotationArm"
                  X1="180"
                  Y1="49"
                  X2="180"
                  Y2="20"
                  Stroke="#F8FCFF"
                  StrokeThickness="1.4" />
            <Ellipse x:Name="RotateHandle"
                     Width="14"
                     Height="14"
                     Fill="#CCE9EEF5"
                     Stroke="#D4181818"
                     StrokeThickness="1.4"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Top"
                     Margin="173,13,0,0"
                     Cursor="Hand"
                     MouseLeftButtonDown="RotateHandle_OnMouseLeftButtonDown" />

            <Rectangle x:Name="TopLeftHandle"
                       Width="12"
                       Height="12"
                       Fill="#CCE9EEF5"
                       Stroke="#D4181818"
                       StrokeThickness="1.2"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="43,43,0,0"
                       Cursor="SizeNWSE"
                       MouseLeftButtonDown="ResizeHandle_OnMouseLeftButtonDown" />
            <Rectangle x:Name="TopRightHandle"
                       Width="12"
                       Height="12"
                       Fill="#CCE9EEF5"
                       Stroke="#D4181818"
                       StrokeThickness="1.2"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="305,43,0,0"
                       Cursor="SizeNESW"
                       MouseLeftButtonDown="ResizeHandle_OnMouseLeftButtonDown" />
            <Rectangle x:Name="BottomLeftHandle"
                       Width="12"
                       Height="12"
                       Fill="#CCE9EEF5"
                       Stroke="#D4181818"
                       StrokeThickness="1.2"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="43,305,0,0"
                       Cursor="SizeNESW"
                       MouseLeftButtonDown="ResizeHandle_OnMouseLeftButtonDown" />
            <Rectangle x:Name="BottomRightHandle"
                       Width="12"
                       Height="12"
                       Fill="#CCE9EEF5"
                       Stroke="#D4181818"
                       StrokeThickness="1.2"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Margin="305,305,0,0"
                       Cursor="SizeNWSE"
                       MouseLeftButtonDown="ResizeHandle_OnMouseLeftButtonDown" />

            <Border x:Name="LockBadge"
                    Width="44"
                    Height="18"
                    Background="#CC1F1F1F"
                    BorderBrush="#E9EEF5"
                    BorderThickness="1"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="49,26,0,0"
                    Visibility="Collapsed">
                <TextBlock Text="LOCK"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#F8FCFF"
                           FontSize="10"
                           FontWeight="SemiBold" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
