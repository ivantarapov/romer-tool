<Window x:Class="Romer.UI.Windows.HotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hotkey Settings"
        Width="420"
        Height="270"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#111111">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="BindingsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  RowHeaderWidth="0"
                  Background="#1B1B1B"
                  Foreground="#E0E0E0"
                  BorderBrush="#333333"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Action" Binding="{Binding Action}" IsReadOnly="True" Width="*" />
                <DataGridTextColumn Header="Gesture" Binding="{Binding Gesture, UpdateSourceTrigger=PropertyChanged}" Width="180" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Width="90" Margin="0,0,8,0" Content="Cancel" Click="Cancel_OnClick" />
            <Button Width="90" Content="Apply" Click="Apply_OnClick" />
        </StackPanel>
    </Grid>
</Window>
